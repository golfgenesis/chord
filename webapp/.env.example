# Override where images are served from (defaults to /images served by Vite dev
# middleware from F:\chord\images). For production, set this to your CDN URL.
# VITE_IMAGE_BASE=https://cdn.yourdomain.com/chord

# Firebase Realtime DB. Without these, the app falls back to a same-browser
# BroadcastChannel mock (good for testing UI on a single machine but no
# cross-device sync). Create a Firebase project, enable Realtime Database, then
# copy these from Project settings -> Web app config.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DB_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
