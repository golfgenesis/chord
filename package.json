{
  "name": "chord",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "data": "node scripts/build-data.mjs",
    "dev": "node scripts/build-data.mjs && vite",
    "build": "node scripts/build-data.mjs && tsc -b && vite build",
    "preview": "vite preview --host",
    "lint": "eslint .",
    "sync": "python3 scripts/sync.py",
    "sync:push": "python3 scripts/sync.py --push",
    "sync:dry": "python3 scripts/sync.py --dry-run",
    "check": "python3 scripts/check_sync.py",
    "check:clean": "python3 scripts/check_sync.py --delete-orphans",
    "chordpro:backfill": "node scripts/local-backfill.mjs",
    "chordpro:upload": "python3 scripts/upload_md_r2.py",
    "chordpro:ship": "node scripts/local-backfill.mjs && node scripts/build-data.mjs && python3 scripts/upload_md_r2.py",
    "chordpro:fix": "node scripts/fix.mjs",
    "chordpro:redo": "node scripts/local-backfill.mjs --force && node scripts/build-data.mjs && python3 scripts/upload_md_r2.py --force",
    "seo:all": "node scripts/build-sitemap.mjs && node scripts/indexnow.mjs && node scripts/social-post.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "brotli": "^1.3.3",
    "firebase": "^12.13.0",
    "idb-keyval": "^6.2.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
