{
  "name": "chord",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "data": "node scripts/build-data.mjs",
    "dev": "npm run data && vite",
    "build": "tsc -b && vite build",
    "build:full": "npm run data && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "sync": "py -3.11 scripts/sync.py",
    "sync:push": "py -3.11 scripts/sync.py --push",
    "sync:dry": "py -3.11 scripts/sync.py --dry-run",
    "check": "py -3.11 scripts/check_sync.py",
    "check:clean": "py -3.11 scripts/check_sync.py --delete-orphans",
    "chordpro": "py -3.11 scripts/extract_chordpro.py",
    "chordpro:next": "py -3.11 scripts/extract_chordpro.py --missing --limit 50 && node scripts/build-data.mjs",
    "chordpro:backfill": "py -3.11 scripts/backfill.py",
    "chordpro:check": "py -3.11 scripts/extract_chordpro.py --check",
    "chordpro:build": "py -3.11 scripts/extract_chordpro.py --regen && node scripts/build-data.mjs",
    "chordpro:regen": "py -3.11 scripts/extract_chordpro.py --regen",
    "chordpro:fix": "node scripts/regen.mjs",
    "chordpro:vlm": "py -3.11 scripts/vlm_chordpro.py",
    "sync:chordpro": "py -3.11 scripts/sync.py --skip-build && py -3.11 scripts/backfill.py"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^12.13.0",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
