yc": 290.5, "conf": 0.6}, {"text": "หยุดความคิดไม่ได้เลย", "x0": 63.0, "x1": 188.5, "cx": 125.8, "yc": 328.2, "conf": 0.5}, {"text": "ชำ ดัด ชาำดัด ช่า ดัด", "x0": 204.5, "x1": 324.0, "cx": 264.2, "yc": 328.2, "conf": 0.1}, {"text": "คิดเสียจนนอนไม่หลับ", "x0": 338.5, "x1": 462.0, "cx": 400.2, "yc": 328.2, "conf": 0.8}, {"text": "มพน . chordtabs .in. th", "x0": 185.0, "x1": 401.0, "cx": 293.0, "yc": 360.0, "conf": 0.1}, {"text": "คนเรามันกีแปลก ชอบแบกอะไรใส่หัวใหมันวุ่นวาย มันภีพอจะเขาใจ กีทยายาม ฺจะท่าใทได สักครั้ง", "x0": 32.5, "x1": 553.0, "cx": 292.8, "yc": 420.5, "conf": 0.2}, {"text": "เกี่ โมงแล็ว", "x0": 69.0, "x1": 128.5, "cx": 98.8, "yc": 512.8, "conf": 0.3}, {"text": "ไม่ยอมหลับไหล", "x0": 163.0, "x1": 258.0, "cx": 210.5, "yc": 513.0, "conf": 0.4}, {"text": "เกี่โมงแล็ว", "x0": 272.5, "x1": 330.5, "cx": 301.5, "yc": 512.8, "conf": 0.5}, {"text": "ไม่นอนอึกเทรอ", "x0": 353.0, "x1": 442.0, "cx": 397.5, "yc": 513.0, "conf": 0.7}]}