นทีนันฺจาต้องบอกลา", "x0": 175.0, "x1": 364.0, "cx": 269.5, "yc": 299.8, "conf": 0.2}, {"text": "อยากบอกว่ารัก  รักเธอเสมอ ก่อน จะเดิน ไปฟังน้าตา", "x0": 91.0, "x1": 351.5, "cx": 221.2, "yc": 328.0, "conf": 0.3}, {"text": "จบก้นเสียที รักฮันยิงใหญ่ ไม่มีอีกแล้า", "x0": 90.5, "x1": 278.0, "cx": 184.2, "yc": 356.0, "conf": 0.5}, {"text": "ฝันฮันยาวไกล", "x0": 283.0, "x1": 356.5, "cx": 319.8, "yc": 357.0, "conf": 0.2}, {"text": "ชัวิตนันต้องเริมใหม่ กับการ'ไม่มีเธอ", "x0": 89.5, "x1": 264.0, "cx": 176.8, "yc": 385.5, "conf": 0.2}, {"text": "ท่อนนิ้น เธอเดยมี่ค้าอย่างไรในาเนี้ยงเป็แอย่างเิ๊ท", "x0": 41.0, "x1": 292.0, "cx": 166.5, "yc": 423.0, "conf": 0.1}, {"text": "จากนีวเม้ม้แเต้องที้นทรมาณฺธิทระทแม้นให้ไหา", "x0": 41.0, "x1": 277.5, "cx": 159.2, "yc": 451.5, "conf": 0.1}, {"text": "กับการไม่เหลือใครแต่ก่อน ฺจะจากไป", "x0": 42.5, "x1": 228.5, "cx": 135.5, "yc": 531.5, "conf": 0.3}, {"text": "จ่า!ว้จันรักเธอ", "x0": 43.0, "x1": 117.0, "cx": 80.0, "yc": 560.0, "conf": 0.2}]}