t": "ขอใท์ความรัก ที่เกิดขืนมานันเป็นรัานิรันดร์", "x0": 310.5, "x1": 543.0, "cx": 426.8, "yc": 186.8, "conf": 0.4}, {"text": "ขอไทความรัก", "x0": 59.5, "x1": 139.5, "cx": 99.5, "yc": 225.5, "conf": 0.8}, {"text": "ที่เกิดยื่นมานันอยู่ตลอดกาล", "x0": 134.5, "x1": 292.5, "cx": 213.5, "yc": 224.8, "conf": 0.3}, {"text": "ขอใทความร้า ที่เกิดขืนมานันเป็นร้านีรันดร์", "x0": 297.0, "x1": 531.5, "cx": 414.2, "yc": 223.8, "conf": 0.5}, {"text": "คืนเปลี่ยมแม่วันผ่าน กาลเปลี่ยนปรวนแปร รักเรามั่นคงแน่มิเปลี่ยนแปร่ไป", "x0": 11.0, "x1": 406.5, "cx": 208.8, "yc": 302.2, "conf": 0.5}, {"text": "เราหล่อหลอมดวงใจ เป็นทนึงเดียวกัน คงจะไม่มีวัน เหินท่างกันไกล", "x0": 12.0, "x1": 376.0, "cx": 194.0, "yc": 339.0, "conf": 0.4}, {"text": "เปี่ยมด้วยความรัก ต่อเธอ", "x0": 11.5, "x1": 150.5, "cx": 81.0, "yc": 377.0, "conf": 0.4}, {"text": "ใจส่งถึงใจเธอ มือจับกันไว้มองดาแล็วเขาใจ ไมต่องเอ่ยคำ", "x0": 11.5, "x1": 334.5, "cx": 173.0, "yc": 484.0, "conf": 0.4}]}