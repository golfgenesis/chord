มองไมเท็นสักท คุณค่ำของเธอคนนี่ ไม่เท็นเลย", "x0": 23.0, "x1": 497.0, "cx": 260.0, "yc": 99.2, "conf": 0.3}, {"text": "ฉันเพิ่งรวามองพลาดไป", "x0": 23.5, "x1": 156.0, "cx": 89.8, "yc": 137.0, "conf": 0.6}, {"text": "เมือไได์เห็นเธอจากมุมนั่น", "x0": 178.5, "x1": 315.5, "cx": 247.0, "yc": 136.5, "conf": 0.3}, {"text": "จากคน ที่เคยยืนคอยที่เดิม เค่อยสเด็นก่าว1ปจากฉัน ภาพเธอทีเห็นเลืองลาง กีเริ่มจะชัด", "x0": 24.0, "x1": 486.0, "cx": 255.0, "yc": 173.0, "conf": 0.1}, {"text": "เพิ่งร่วำฉันไมได้ต็องการคนทีดีพอ เพื่อมารักคัน(เพื่อที่มารัากัน)", "x0": 53.5, "x1": 397.5, "cx": 225.5, "yc": 221.2, "conf": 0.2}, {"text": "เพิ่งรุ่วาฉันต่องการแค่คนทิพอดิกับฉัน และคนนั้นคือเธอ", "x0": 42.5, "x1": 342.5, "cx": 192.5, "yc": 258.5, "conf": 0.3}, {"text": "เพราะสายตามันหลอกฉัน หรือมือไครมาปิดไว้", "x0": 91.5, "x1": 340.5, "cx": 216.0, "yc": 306.2, "conf": 0.4}, {"text": "เกีสายตาฉันยาวจมเกินไปมองเลยทัวใจที่ใกล้แค่เพียงเอื่อมคว่า", "x0": 71.0, "x1": 412.5, "cx": 241.8, "yc": 342.5, "conf": 0.2}, {"text": "ต่องการเธอไดียนไหม ตะโกนใท้ฟังดังาว่ารัก ขอเธออย่าเด็น1ปจากฉัน ฺช่วยทันมองกันอึกที", "x0": 71.0, "x1": 559.0, "cx": 315.0, "yc": 380.0, "conf": 0.2}, {"text": "ถึงโลกหมุนไปทางทิศใด(ถึงโลกจะหมฺนจะเปลี่ยนไปแค่ไทน) ถึงต้องพบใครไหม่เสมอ", "x0": 23.0, "x1": 483.0, "cx": 253.0, "yc": 428.2, "conf": 0.3}, {"text": "จากวันนีจะมองเห็นใคร ใกล่หรือไกลจะเท็นแต่เธอ ภาพเธอเทานันจะคงอยฺู่ในดาของฉัน", "x0": 24.0, "x1": 495.0, "cx": 259.5, "yc": 464.0, "conf": 0.4}, {"text": "ใจทิ่มีแต่เธอมันเทียงต่องการจะหยุด หยุดตรงทีนิที่เธอคนนี่ อย่าจากไปได้ไหม", "x0": 23.0, "x1": 444.5, "cx": 233.8, "yc": 571.0, "conf": 0.2}, {"text": "(เพราะสายดามันหลอกฉัน หรือมือใครมาปิดไว้)", "x0": 71.5, "x1": 329.5, "cx": 200.5, "yc": 622.2, "conf": 0.5}, {"text": "(เกีสายตาฉันยาวจนเกินไบ มองเลยหัวใจที่ใกล้แค่เพียงเอื่อมคว่า)", "x0": 70.5, "x1": 422.5, "cx": 246.5, "yc": 656.8, "conf": 0.3}, {"text": "ต่องการเธอได้ยินไหม ฺตะโกนใททังดังๆว่ารัก(จะมีแด่เธอคมเดียวเท่านั้น)", "x0": 71.0, "x1": 466.0, "cx": 268.5, "yc": 694.8, "conf": 0.1}, {"text": "วำรัาเธอ(อย่าเด็น.ปจากฉัน ภีมีเธอ เท่านัน)", "x0": 71.0, "x1": 307.0, "cx": 189.0, "yc": 730.8, "conf": 0.2}, {"text": "ฉันรักเธอ", "x0": 322.5, "x1": 377.5, "cx": 350.0, "yc": 732.2, "conf": 0.7}]}