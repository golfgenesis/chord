วยวันและคืนที่่านกีฬาใทฉันได็พบเจอกับเวลา", "x0": 37.0, "x1": 347.5, "cx": 192.2, "yc": 133.5, "conf": 0.2}, {"text": "เขามาเป็นเพื่อนใจ", "x0": 361.5, "x1": 465.0, "cx": 413.2, "yc": 133.8, "conf": 0.5}, {"text": "เวลาเอ่ย  เธอไม่เคยท่างไกล มืแต่เธอคอยหมุมเวียนอยู่ใกล้า", "x0": 36.5, "x1": 364.5, "cx": 200.5, "yc": 172.0, "conf": 0.3}, {"text": "คอยรักษาแผลใจใท่ทายดี", "x0": 395.0, "x1": 539.5, "cx": 467.2, "yc": 171.0, "conf": 0.6}, {"text": "เจ้าเวลา", "x0": 96.0, "x1": 147.0, "cx": 121.5, "yc": 226.0, "conf": 0.7}, {"text": "ขอบใจนะที่คอยดูแลเมื่อฉันเสียใจ", "x0": 182.5, "x1": 369.0, "cx": 275.8, "yc": 226.8, "conf": 0.6}, {"text": "ใท้ความเจ็บชำนันมันเลือนลางหายไป", "x0": 85.0, "x1": 290.0, "cx": 187.5, "yc": 262.2, "conf": 0.4}, {"text": "ใหฉันเขาใจและไดรู่", "x0": 313.5, "x1": 426.0, "cx": 369.8, "yc": 264.2, "conf": 0.6}, {"text": "เจ้ำเวลา", "x0": 84.5, "x1": 134.5, "cx": 109.5, "yc": 300.5, "conf": 0.6}, {"text": "จากวันบันเธอทำไทจันได็ทบทวนทัวใจ", "x0": 170.5, "x1": 381.5, "cx": 276.0, "yc": 299.2, "conf": 0.3}, {"text": "เพราะ", "x0": 85.5, "x1": 121.0, "cx": 103.2, "yc": 338.2, "conf": 0.7}, {"text": "เทุกนาทีทีเธอให1วี", "x0": 115.5, "x1": 222.0, "cx": 168.8, "yc": 336.8, "conf": 0.4}, {"text": "มีค่ากว่าสิ่งไทน เธอร์ไหมเจาเวลา", "x0": 268.0, "x1": 454.5, "cx": 361.2, "yc": 337.2, "conf": 0.4}, {"text": "เวลาเอ่ย  เธอไม่เคยท่างไกล มีแต่เธอคอยหมุมเวียนอยู่ใกล่จ", "x0": 37.0, "x1": 364.0, "cx": 200.5, "yc": 449.2, "conf": 0.2}, {"text": "รักษาแผลใจจนทายดี", "x0": 407.5, "x1": 529.0, "cx": 468.2, "yc": 448.0, "conf": 0.8}]}