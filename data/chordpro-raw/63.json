"yc": 628.7, "conf": 0.0}, {"text": "A", "x0": 14.3, "x1": 30.3, "cx": 22.3, "yc": 647.3, "conf": 1.0}, {"text": "Idivuum Savlvivlaum .M578ingavnavilsaauan indviauiuatasvii mqnfolu", "x0": 9.3, "x1": 503.0, "cx": 256.2, "yc": 666.3, "conf": 0.0}, {"text": "Instru / D / Em / A / D / Bm / Em / A / A /", "x0": 11.3, "x1": 309.7, "cx": 160.5, "yc": 703.5, "conf": 0.5}, {"text": "(*, ** )", "x0": 10.3, "x1": 76.3, "cx": 43.3, "yc": 734.8, "conf": 0.9}, {"text": "Outro / Em / A /", "x0": 10.7, "x1": 131.0, "cx": 70.8, "yc": 762.7, "conf": 0.8}, {"text": "1 D Dsus2 / D Dsus4 / ( 4 Times ) ( Fade out )", "x0": 52.3, "x1": 371.3, "cx": 211.8, "yc": 782.3, "conf": 0.5}], "th": [{"text": "ไมรู่", "x0": 11.5, "x1": 39.5, "cx": 25.5, "yc": 64.2, "conf": 0.6}, {"text": "เลยใช่ไทม", "x0": 49.0, "x1": 112.5, "cx": 80.8, "yc": 63.0, "conf": 0.3}, {"text": "ตรงนี่มันยังมีใครอึกคน", "x0": 135.5, "x1": 261.5, "cx": 198.5, "yc": 62.2, "conf": 0.4}, {"text": "เค้าท่วงใย อยากเท็นเธอยิมได์ลักที", "x0": 285.0, "x1": 477.0, "cx": 381.0, "yc": 62.0, "conf": 0.2}, {"text": "กีไมรู", "x0": 9.5, "x1": 49.0, "cx": 29.2, "yc": 100.0, "conf": 0.6}, {"text": "ทำอย่างไร", "x0": 61.0, "x1": 124.0, "cx": 92.5, "yc": 100.2, "conf": 0.9}, {"text": "ปล่อยเธอ1วคนเดียวคงไม่ดี", "x0": 135.0, "x1": 286.0, "cx": 210.5, "yc": 100.2, "conf": 0.6}, {"text": "สิงสัยว่าอะไรทำเธอกังวล  จนเป็นอย่างนี่", "x0": 305.5, "x1": 524.5, "cx": 415.0, "yc": 99.0, "conf": 0.5}, {"text": "วันทิเศร้าชซีมาในหัาใจ วันทิลอยยิ่มเธอนันได้หายไป วัมทิอะไรกึดูเหมือนวามัน กำลังจะไม่ไหว", "x0": 9.5, "x1": 519.5, "cx": 264.5, "yc": 137.5, "conf": 0.2}, {"text": "เธอยังมีฉันเมือไรกีตามฺที่เธอนั้นไม่มีใคร เธอยังมีจันไม่วาเมือไทร่ลึงใครเค้าไมสน", "x0": 71.0, "x1": 504.5, "cx": 287.8, "yc": 184.5, "conf": 0.1}, {"text": "ไม่ต้องหงอยและไม่ต่องเทงา เกียังมีฉันทั้งคน ฺยังใง(ฉันกือยู่ขางเธอ)(กีไมไปไทน)", "x0": 59.0, "x1": 502.5, "cx": 280.8, "yc": 222.0, "conf": 0.2}, {"text": "อย่างนอย แค่คอนนี้ จะรับทังเรื่องราวเธอทุกอย่าง อย่างดั้งใจ กึคงทาไดเพียงเท่านี่", "x0": 15.0, "x1": 460.0, "cx": 237.5, "yc": 317.8, "conf": 0.2}, {"text": "เพราะว่าไมรู้  มันแค่ไทน", "x0": 11.5, "x1": 151.0, "cx": 81.2, "yc": 356.5, "conf": 0.3}, {"text": "บาดแผลที่จิตใจเธอมั่นมี และมันคงไม่จริงถาใหพดไปที่ ว่ำฉันเข้าใจ", "x0": 158.5, "x1": 532.0, "cx": 345.2, "yc": 356.2, "conf": 0.2}, {"text": "แต่วันที่เศร้าชซึมตในหัวใจ วันทีลอยยิ้มเธอมั้นไเด้หายไป ฉันขอให์เธอได้ทังค่าพด ของฉันเอาไว้", "x0": 10.0, "x1": 523.5, "cx": 266.8, "yc": 391.8, "conf": 0.1}, {"text": "และจะมีฉันเมื่อไหร่ก็ดามทีเธอมั้นมีนำดา จะอย่ขางๆเธอไปจนกว่าเธอจะบอกว่าไหว", "x0": 97.0, "x1": 545.0, "cx": 321.0, "yc": 470.0, "conf": 0.3}, {"text": "จะเป็นเพื่อนร่วมสุยและทุกยํ จะเดินเคียงข่างกันไป ยังใงฉันกือยู่ย่างเธอ", "x0": 77.5, "x1": 463.5, "cx": 270.5, "yc": 507.5, "conf": 0.2}, {"text": "หากว่าำเธอไม่ร่กือยากใหรูอึกครั่ง ว่ายังมีมันยังมัคนทื่อยากจะเท็นเธอยิ่ม", "x0": 11.0, "x1": 394.0, "cx": 202.5, "yc": 555.5, "conf": 0.2}, {"text": "ไม่ต่องกลัวนะ ไมต่องกังวลละ ถึงแม่ฉัน จะไม่เขาใจว่าอะไรเกิดขึ่น จริง", "x0": 11.5, "x1": 384.0, "cx": 197.8, "yc": 590.8, "conf": 0.4}, {"text": "ฉันคนนีกียังจะเป็นเหมือนเดิมเสมอ คือจะยืนอยู่ข่างๆร่วมทางไปพร่อมเธอ", "x0": 11.0, "x1": 403.0, "cx": 207.0, "yc": 629.2, "conf": 0.3}, {"text": "ใสใหเด็มที รองไท้ให้เด็มที่ เพราะว่าเธอมาถึงนีเธอจะบอกว่ายังมีฉันยืนอยู่ตรงนี้ ทุกาครั่งไป", "x0": 10.5, "x1": 501.5, "cx": 256.0, "yc": 665.5, "conf": 0.2}]}