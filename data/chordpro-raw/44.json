text": "WWW chordtabs.in.th", "x0": 372.3, "x1": 571.0, "cx": 471.7, "yc": 582.5, "conf": 0.7}], "th": [{"text": "รักแท้ ภเลไมได้", "x0": 95.0, "x1": 191.0, "cx": 143.0, "yc": 30.2, "conf": 0.1}, {"text": "ความรัก", "x0": 40.0, "x1": 84.0, "cx": 62.0, "yc": 117.5, "conf": 0.9}, {"text": "ขอิงเธอิ", "x0": 98.5, "x1": 140.5, "cx": 119.5, "yc": 118.0, "conf": 0.3}, {"text": "เสียงทับอกฉัน  ว่าเธอท่างใย", "x0": 163.5, "x1": 306.5, "cx": 235.0, "yc": 117.0, "conf": 0.1}, {"text": "มื่อนั้น", "x0": 39.0, "x1": 75.0, "cx": 57.0, "yc": 145.5, "conf": 0.7}, {"text": "ปอิปเธีอิ", "x0": 85.0, "x1": 127.0, "cx": 106.0, "yc": 147.5, "conf": 0.1}, {"text": "ทีแตะหน้าผาคฉันาันทีนันไม่สบาย", "x0": 153.0, "x1": 325.0, "cx": 239.0, "yc": 146.0, "conf": 0.3}, {"text": "ทกๆฉาก{เพราะทกฉาก) ทกตอน ไม่เคยจางหาย แม้าะผ่านเนิ่นนานเท่าไร", "x0": 87.5, "x1": 446.5, "cx": 267.0, "yc": 190.5, "conf": 0.3}, {"text": "และทกฉาก ทกตอน นั้นคอยตอกย้ำสิงทีนันเปิน ตั้งแต่เสียเธอ'ไป", "x0": 89.0, "x1": 407.5, "cx": 248.2, "yc": 218.5, "conf": 0.2}, {"text": "**าานันเปีแคน", "x0": 113.0, "x1": 192.5, "cx": 152.8, "yc": 261.5, "conf": 0.3}, {"text": "โงเทนือ  ใครห มีรักแท้อยู่", "x0": 214.5, "x1": 347.5, "cx": 281.0, "yc": 262.8, "conf": 0.1}, {"text": "ดูแลไม่ได้", "x0": 355.5, "x1": 410.5, "cx": 383.0, "yc": 262.5, "conf": 0.7}, {"text": "อะรู้ค่ามัน", "x0": 129.0, "x1": 178.5, "cx": 153.8, "yc": 292.2, "conf": 0.5}, {"text": "เกิสายเกินไป ปาดร้าวคิดอยากย้อน เรื่องราาแค่ไทนได้แต่ฝัน", "x0": 199.5, "x1": 494.0, "cx": 346.8, "yc": 290.5, "conf": 0.2}, {"text": "ต่อจน  เหมือนเดิม", "x0": 39.5, "x1": 134.0, "cx": 86.8, "yc": 364.2, "conf": 0.3}, {"text": "รูบเมือก่อนนั้น ทีมันขาดไป", "x0": 157.0, "x1": 294.0, "cx": 225.5, "yc": 363.0, "conf": 0.2}, {"text": "แต่ทาง", "x0": 41.0, "x1": 82.0, "cx": 61.5, "yc": 393.5, "conf": 0.9}, {"text": "ขฮงเรา", "x0": 88.0, "x1": 128.0, "cx": 108.0, "yc": 394.2, "conf": 0.3}, {"text": "อะต่อได้อักไทม ฺหรือว่านันต้องฟาใจ", "x0": 149.0, "x1": 328.0, "cx": 238.5, "yc": 392.8, "conf": 0.2}, {"text": "บอกหน่อยทีไทน\"อจะมี ประตูใท้จีแย้อนไปคืนาัน", "x0": 52.5, "x1": 294.0, "cx": 173.2, "yc": 494.2, "conf": 0.2}, {"text": "ทีนันมีเธออยู่ จะยอดแลอีกครั่ง", "x0": 39.5, "x1": 194.0, "cx": 116.8, "yc": 523.5, "conf": 0.3}, {"text": "wพพ. chordtabs.in. th", "x0": 374.0, "x1": 570.5, "cx": 472.2, "yc": 582.5, "conf": 0.3}]}