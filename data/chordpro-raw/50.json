.0, "cx": 474.8, "yc": 168.5, "conf": 0.3}, {"text": "ทกาน_ฺฉาบจนานนี ชัวิตทีเราต้องมี จากนี้ต้องฟาต้าเซ่นไร", "x0": 18.5, "x1": 308.0, "cx": 163.2, "yc": 256.5, "conf": 0.2}, {"text": "นทaกี่", "x0": 17.5, "x1": 68.0, "cx": 42.8, "yc": 278.2, "conf": 0.1}, {"text": "ทียังรินไทล จากคาามรักทีมีฬั่งใจสุดท้ายเค้านั้นทายไป", "x0": 49.5, "x1": 326.5, "cx": 188.0, "yc": 284.5, "conf": 0.4}, {"text": "จบก้นซักที จบก้นแคนีไม่มีใครมีแต่ฟ้ำทีมองมาเห็นน้าตำ_ภากนี้ไป", "x0": 20.5, "x1": 364.0, "cx": 192.2, "yc": 357.5, "conf": 0.2}, {"text": "โปรดเถิดฟ้า กำไม่สงมาใท้เธอมีใจ ก็่บอก", "x0": 20.5, "x1": 228.5, "cx": 124.5, "yc": 385.8, "conf": 0.3}, {"text": "ก้น", "x0": 245.5, "x1": 266.0, "cx": 255.8, "yc": 386.5, "conf": 0.3}, {"text": "ไได้", "x0": 286.5, "x1": 306.0, "cx": 296.2, "yc": 386.2, "conf": 0.4}, {"text": "ไทม", "x0": 326.0, "x1": 352.0, "cx": 339.0, "yc": 385.8, "conf": 0.7}, {"text": "เทตใดต้องมาฬาร้ายก้น", "x0": 373.0, "x1": 490.5, "cx": 431.8, "yc": 386.8, "conf": 0.6}, {"text": "จากนีเรืองราวทีมี กิใท้ลืมมันไป อย่า", "x0": 21.0, "x1": 203.5, "cx": 112.2, "yc": 414.0, "conf": 0.2}, {"text": "จ่า", "x0": 220.0, "x1": 239.0, "cx": 229.5, "yc": 415.8, "conf": 0.2}, {"text": "ได้", "x0": 255.0, "x1": 275.5, "cx": 265.2, "yc": 414.8, "conf": 0.6}, {"text": "ไทม", "x0": 296.0, "x1": 322.0, "cx": 309.0, "yc": 415.2, "conf": 0.9}, {"text": "ว่ามีใครทิเคยฟาร้าย ว่ามีใครพัมาฟาร้าย คนอย่างนัน", "x0": 20.5, "x1": 282.5, "cx": 151.5, "yc": 443.5, "conf": 0.2}]}