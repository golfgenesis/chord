ยน ฺหากยังหมุนเวียนวน อยู่อย่างนี่", "x0": 20.0, "x1": 309.5, "cx": 164.8, "yc": 389.5, "conf": 0.4}, {"text": "เผื่อใจเอาใว่ก่อน ทิศทางลมฺไม่แม่นอน", "x0": 19.5, "x1": 235.5, "cx": 127.5, "yc": 425.5, "conf": 0.2}, {"text": "เปลี่ยนไป", "x0": 22.0, "x1": 82.0, "cx": 52.0, "yc": 502.2, "conf": 0.6}, {"text": "หวั่น1หว", "x0": 87.5, "x1": 140.5, "cx": 114.0, "yc": 502.5, "conf": 0.3}]}