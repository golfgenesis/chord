พียงแค่อิกวันหนึง ของเดือน ของปีของชิวิดที่ไมเคยสมบูรณ์แบบ", "x0": 12.5, "x1": 525.5, "cx": 269.0, "yc": 135.8, "conf": 0.4}, {"text": "กล่อมใจใท่ดัวเอง เชื่อว่าจากตอนนี้ คือเวลา ที่เหลือที่ไมมีเธอ", "x0": 43.5, "x1": 376.5, "cx": 210.0, "yc": 182.2, "conf": 0.2}, {"text": "และไฟต็องสินเชื้อ เพือหยุดการพร่าเทอ เป็นสัญญา พรุ่งมิจะก้าวต่อไป", "x0": 30.0, "x1": 412.5, "cx": 221.2, "yc": 220.8, "conf": 0.3}, {"text": "แต่ยังมี อีกเสียงหนึง ที่เรียกร่องเธอดังก็องอยฺู่หรือเป็น ทวังเทียมฺที่ชีวิตเอาแอบ ซ่อนไวข่างใน", "x0": 80.5, "x1": 586.0, "cx": 333.2, "yc": 268.2, "conf": 0.1}, {"text": "ฉันอาจหยายามไม่มาก พอ ที่จะปลดเปลื่องดนใทพันจากการเสิยศนย์", "x0": 12.5, "x1": 380.5, "cx": 196.5, "yc": 346.0, "conf": 0.3}, {"text": "ฉันอาจทยายามไดนอยไปทีจะปลดเปลื่องใจ ใหพันจากการจองจำ", "x0": 12.5, "x1": 372.0, "cx": 192.2, "yc": 382.2, "conf": 0.4}, {"text": "แต่ต่องรอ อีกนานเท่าไทร่ กว่าในส่วนลึก คลี่คลายและพันผ่าน", "x0": 13.0, "x1": 347.5, "cx": 180.2, "yc": 419.5, "conf": 0.5}, {"text": "เมื่อความ รูสึกต่องการ ยังคลุมอยู่เหนือ แก่นสารของหัวใจ", "x0": 12.5, "x1": 324.5, "cx": 168.5, "yc": 458.0, "conf": 0.4}]}