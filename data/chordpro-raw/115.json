14.0, "yc": 47.2, "conf": 0.1}, {"text": "ขออธิษฐานต่อดางดาาทาให้จัน\"ไม่ต้อง อยู่เดียาดาย", "x0": 90.5, "x1": 346.0, "cx": 218.2, "yc": 76.0, "conf": 0.3}, {"text": "และฟาใพ้เราเจอใครสักคน", "x0": 351.0, "x1": 484.0, "cx": 417.5, "yc": 76.2, "conf": 0.6}, {"text": "เหม่อมองคาามรักทีมันหลดลอย ปล่อยใจดางน้อยเฝ้าคอยคาามหาัง", "x0": 56.0, "x1": 392.5, "cx": 224.2, "yc": 148.5, "conf": 0.7}, {"text": "กี้ศแหมี่แล้านทติแผ่านไนิการะมใครไหมที่ยันฝ้ารอ", "x0": 54.0, "x1": 307.5, "cx": 180.8, "yc": 170.8, "conf": 0.1}, {"text": "\"อยู่กับคาามเหงามานาน มันทรมาน เทมือนอยู่นแทางแสนไกล", "x0": 79.5, "x1": 387.5, "cx": 233.5, "yc": 222.0, "conf": 0.4}, {"text": "ก่อนมัน จะสายเคินไป ทกลมหายใจมันอยฺู่เพือ", "x0": 79.5, "x1": 318.5, "cx": 199.0, "yc": 250.5, "conf": 0.5}, {"text": "รอใครสักคน", "x0": 328.5, "x1": 394.0, "cx": 361.2, "yc": 250.5, "conf": 1.0}, {"text": "ทากใคืนนีนันมองหมู่ดาว กลางคนทีเพงาในสายสมหนาว", "x0": 55.0, "x1": 344.5, "cx": 199.8, "yc": 321.8, "conf": 0.6}, {"text": "อยากจะเจอรักทีมื่อย่ารึง", "x0": 53.5, "x1": 181.0, "cx": 117.2, "yc": 344.8, "conf": 0.2}, {"text": "อยากสัมผัสรักพันันต้องการ", "x0": 189.0, "x1": 324.0, "cx": 256.5, "yc": 350.2, "conf": 0.6}, {"text": "ใครซักคนทนึ่งเพียงใครสักคนหนึง แคเท่านั้น แค่เท่านั้น แค่เท่านั้น", "x0": 81.5, "x1": 416.5, "cx": 249.0, "yc": 452.2, "conf": 0.3}]}