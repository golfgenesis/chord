ลัวไมต่องหวันไทว ไม่ต่องเกรงใจเธอไม่ต่องกังวล", "x0": 15.5, "x1": 350.0, "cx": 182.8, "yc": 90.5, "conf": 0.2}, {"text": "สิ่งทิฉันนันทุ่มเทให่กับเธอ ไมเคยดิดอะไร", "x0": 347.0, "x1": 577.0, "cx": 462.0, "yc": 90.8, "conf": 0.3}, {"text": "แค่อยากจะดูแลเธอเท่านั่น", "x0": 15.0, "x1": 162.0, "cx": 88.5, "yc": 129.0, "conf": 0.8}, {"text": "ไม่ใด้ต่องการใหเธอมาสนใจได้ใกล์ชิดไเด็เป็นท่วงอยู่เสมอ แค่นิกีสุยใจแล้ว", "x0": 167.0, "x1": 574.0, "cx": 370.5, "yc": 128.0, "conf": 0.2}, {"text": "ไมใด็หวังวำเธอ  จะกมมองคนธรรมดา", "x0": 46.5, "x1": 254.5, "cx": 150.5, "yc": 182.8, "conf": 0.4}, {"text": "ไม่ใด้คิดคว่าดาวที่อยู่บนฟ้า", "x0": 318.5, "x1": 473.5, "cx": 396.0, "yc": 183.5, "conf": 0.5}, {"text": "แค่คนเดินดินคนธรรมดา ไม่มราคา ไมมิคณคาใด", "x0": 83.0, "x1": 346.5, "cx": 214.8, "yc": 240.0, "conf": 0.4}, {"text": "ไม่ใช่ผู่วิเศษ อย่างใครา มีแด่ดัวและหัวใจเท่านึ(ที่พอจะไหเธอ)(ที่ใหเธอไปแล้ว)", "x0": 62.5, "x1": 500.0, "cx": 281.2, "yc": 276.8, "conf": 0.1}, {"text": "เธอไม่ต้องดอบแทนอะไรฉัน", "x0": 16.5, "x1": 171.5, "cx": 94.0, "yc": 331.0, "conf": 0.6}, {"text": "แค่บอกด่อกันในลิ่งที่ต้องการ", "x0": 181.5, "x1": 342.5, "cx": 262.0, "yc": 330.5, "conf": 0.3}, {"text": "คนหนี่ไม่เคยเกี่ยงวาเรื่องนั่น จะยากเย็นสักเพียงไหน", "x0": 14.5, "x1": 296.5, "cx": 155.5, "yc": 367.2, "conf": 0.4}, {"text": "แค่คนเดินดินคนธรรมดา ไม่ม้ราคา ไม่ม้คณค่าใด", "x0": 63.5, "x1": 326.0, "cx": 194.8, "yc": 499.0, "conf": 0.3}, {"text": "ไม่ใช่ผู่วิเศษ อย่างใครจ มีแต่ด้วและทัวใจเทานึทีพอจะใหเธอ", "x0": 63.0, "x1": 396.5, "cx": 229.8, "yc": 534.5, "conf": 0.2}]}