0": 58.5, "x1": 408.5, "cx": 233.5, "yc": 112.8, "conf": 0.3}, {"text": "ยังไม่ร้ต้องนานเอีกเท่าไร  จะได์บอกศาคานี้ออกไป", "x0": 85.0, "x1": 333.0, "cx": 209.0, "yc": 142.2, "conf": 0.1}, {"text": "นันเองกิมั่นใจ ว่าพร้อมทกอย่างแต่ขาดเพียงเรืองเดียว", "x0": 77.0, "x1": 346.0, "cx": 211.5, "yc": 171.0, "conf": 0.2}, {"text": "คนทือยากาะทังนัน", "x0": 128.5, "x1": 226.5, "cx": 177.5, "yc": 213.8, "conf": 0.3}, {"text": "อะมีบักคนทรือเปล่า", "x0": 290.5, "x1": 389.5, "cx": 340.0, "yc": 214.2, "conf": 0.3}, {"text": "คนท้อยากได้คาามรัก", "x0": 109.5, "x1": 218.0, "cx": 163.8, "yc": 242.5, "conf": 0.6}, {"text": "ลากใจฉันไป", "x0": 278.5, "x1": 344.0, "cx": 311.2, "yc": 243.0, "conf": 0.4}, {"text": "มัพรือเปล่า", "x0": 379.0, "x1": 438.0, "cx": 408.5, "yc": 242.8, "conf": 0.3}, {"text": "มันคงต้องมีอักคน", "x0": 69.5, "x1": 160.5, "cx": 115.0, "yc": 287.0, "conf": 0.5}, {"text": "มันต้องมืคนเข้าใจค้น พร้อมฺจะฝังทีนันขูดไบ", "x0": 169.0, "x1": 392.5, "cx": 280.8, "yc": 286.8, "conf": 0.2}, {"text": "วันนี้กียังเฝ้าคอย มองยู้คนนับร้อยนับพัน  เธอคนนั้นจะอยู่ทีไหน", "x0": 70.0, "x1": 384.5, "cx": 227.2, "yc": 316.2, "conf": 0.2}, {"text": "ไม่อยากจะบอกรักใคร แล้าต้องกลายเป็นสมทัพัดผ่านไปฺมีใครซักบ้าง\"ไหม", "x0": 58.5, "x1": 425.5, "cx": 242.0, "yc": 387.8, "conf": 0.2}, {"text": "หมดคาามหมาย ก้ำอยู่ในฟ้าใจ", "x0": 96.5, "x1": 248.0, "cx": 172.2, "yc": 417.8, "conf": 0.6}, {"text": "ไม่ขูด'ไป", "x0": 264.5, "x1": 313.5, "cx": 289.0, "yc": 418.0, "conf": 0.5}, {"text": "อยากมีใคร ทีบิ้งคับ คานี้", "x0": 58.5, "x1": 199.5, "cx": 129.0, "yc": 445.2, "conf": 0.3}, {"text": "มีใครอักคนบ้าง'ไทม", "x0": 205.0, "x1": 306.0, "cx": 255.5, "yc": 446.2, "conf": 0.5}, {"text": "คนทือยากจะฟังนันเน้นยังคงตามหา)จะมีอักคนหรื่อเปล่า", "x0": 49.5, "x1": 334.5, "cx": 192.0, "yc": 489.0, "conf": 0.1}, {"text": "มี่หระอเปส้ำ^", "x0": 322.5, "x1": 404.5, "cx": 363.5, "yc": 510.8, "conf": 0.0}, {"text": "คนทือยากได้ความรักไขอเป็นเธอได้\"ไทมาจากใจนันไป", "x0": 49.5, "x1": 322.5, "cx": 186.0, "yc": 517.8, "conf": 0.2}, {"text": "จุมี่ชักคนหรือเนลำ", "x0": 231.5, "x1": 337.0, "cx": 284.2, "yc": 540.2, "conf": 0.1}, {"text": "คนทือยากจะทังฉันไน้แยังคงตามทา)", "x0": 49.5, "x1": 236.0, "cx": 142.8, "yc": 547.0, "conf": 0.3}, {"text": "ท่างีเนล้ำ", "x0": 305.5, "x1": 375.0, "cx": 340.2, "yc": 569.5, "conf": 0.1}, {"text": "ขอแค่ใครซักคนนั้นเขอเป็นเธอได้ไทม)มาเติมฟ้าใจ", "x0": 49.5, "x1": 308.5, "cx": 179.0, "yc": 576.2, "conf": 0.3}]}