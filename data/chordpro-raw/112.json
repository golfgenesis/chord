ลากีผ่านมานานแจ้าตั้งทลายบีตั้งหลายบี", "x0": 194.5, "x1": 415.5, "cx": 305.0, "yc": 68.5, "conf": 0.5}, {"text": "ต้องทน จมอยู่กับคาามเพงา  อยากจะมัคนคางอย่างใครเขา ซักที  ซักที", "x0": 55.0, "x1": 407.0, "cx": 231.0, "yc": 98.8, "conf": 0.1}, {"text": "+บีวิธือย่างไรใท้ใครอักคนเข้ามารักษ้นที", "x0": 67.5, "x1": 265.5, "cx": 166.5, "yc": 140.8, "conf": 0.2}, {"text": "ใครร้ดีวิธีขัแตอนแบบไทน", "x0": 67.0, "x1": 196.5, "cx": 131.8, "yc": 169.5, "conf": 0.5}, {"text": "กล้างัแกล้าม้าตักดานหลายบีเปีแอย่างนึ้ทกที", "x0": 111.0, "x1": 334.0, "cx": 222.5, "yc": 213.2, "conf": 0.3}, {"text": "ขอคนมาบอกทางฉันที", "x0": 91.0, "x1": 205.0, "cx": 148.0, "yc": 242.8, "conf": 0.6}, {"text": "มืงัแมีใจทีรักภักดีรอแบ่งใจทีมี", "x0": 90.5, "x1": 242.0, "cx": 166.2, "yc": 272.0, "conf": 0.2}, {"text": "ขอิคนมาเมตตาฉันหน่อย", "x0": 91.5, "x1": 215.5, "cx": 153.5, "yc": 301.5, "conf": 0.4}, {"text": "จะทาอย่างไรทากไม่สนฺเวลากิเริมจะผ่านพ้นไปทกที ไปทุกที", "x0": 56.5, "x1": 362.0, "cx": 209.2, "yc": 373.2, "conf": 0.2}, {"text": "ทากมันยังเป็นอยู่อย่างนี้ เท็นทีต้องทนอยู่คนเดียา อีกแล้าซ อึกแล้าซิ", "x0": 54.0, "x1": 398.5, "cx": 226.2, "yc": 402.0, "conf": 0.2}, {"text": ".ฮ้โจโจ ไไอเรืองแค่นี้มัน'ไม่ถึงตายทรอกเรา'ไม่ได้าโม้าโม้", "x0": 55.5, "x1": 326.0, "cx": 190.8, "yc": 473.5, "conf": 0.2}, {"text": "ทัคณคนสายเขาชอบเดินควงศับคนทีาิกโก", "x0": 55.0, "x1": 264.0, "cx": 159.5, "yc": 502.8, "conf": 0.2}, {"text": "อับรกาอลโว รูปหล่อกล้ามโต กับเรากิโนโน เกีไม่เป็นไร", "x0": 55.0, "x1": 322.0, "cx": 188.5, "yc": 532.2, "conf": 0.2}, {"text": "แครอสักวันใ้ฬ้าสงสาร.ละดลบันดาล", "x0": 55.5, "x1": 245.5, "cx": 150.5, "yc": 561.0, "conf": 0.4}, {"text": "ให้เป็นคูตนาหงันฺทียังไม่พบพาน", "x0": 241.0, "x1": 406.5, "cx": 323.8, "yc": 561.8, "conf": 0.3}, {"text": "รอนานธักราคาญ รอแล้ารอเล่านั่งเฝ้าแต่รอ เมือไทร่จะมา", "x0": 54.5, "x1": 333.5, "cx": 194.0, "yc": 590.2, "conf": 0.3}]}