# Copy to .env.local and fill in your own values. .env.local is gitignored.

# Vite / web client ──────────────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DB_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# Where the client fetches chord-sheet images from. Point this at the
# R2 Custom Domain (e.g. https://img.yourdomain.com) that has a
# Transform Rule layered on it returning Access-Control-Allow-Origin
# headers. The Transform Rule supplies CORS so cache.put() and
# crossOrigin="anonymous" both work — no opaque-response padding tax.
#
# Use the same value in dev (here) and prod (Pages dashboard
# Settings → Environment variables → Production).
# VITE_IMAGE_BASE=https://img.yourdomain.com

# Where the client fetches ChordPro markdown sheets (.md) from. Defaults to
# `${VITE_IMAGE_BASE}/md` when unset, so you usually DON'T need to set this —
# the .md files are uploaded to the same R2 bucket under the md/ prefix by
# scripts/upload_md_r2.py. Leave it unset in local dev to use the same-origin
# /md route (vite serves data/songs-md). Also read by the SEO Pages Function.
# VITE_TEXT_BASE=https://img.yourdomain.com/md

# Gemini ChordPro backfill (scripts/gemini-backfill.mjs = npm run chordpro:backfill).
# Free key from https://aistudio.google.com/apikey. Either name is accepted.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Python scripts (R2 bucket) ─────────────────────────────────────────────
# Picked up by scripts/_env.py → scripts/_r2.py. Required by upload_r2.py.
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# Optional overrides (defaults baked into scripts/_r2.py):
# R2_ENDPOINT=
# R2_BUCKET=

# Python scripts (image conversion) ──────────────────────────────────────
# Full path to cwebp.exe used by scripts/convert_to_webp.py. Only needed
# if cwebp isn't on PATH and isn't at one of the auto-discovered locations
# (C:\tools\libwebp\bin\, C:\Program Files\libwebp\bin\, C:\libwebp\bin\,
# %LOCALAPPDATA%\libwebp\bin\). Download cwebp from
# https://developers.google.com/speed/webp/download
# CWEBP=C:\tools\libwebp\bin\cwebp.exe
