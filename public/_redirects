# Firebase Auth reserved paths — rewrite to our Cloudflare Pages Function
# at /auth-proxy/*. Cloudflare ignores function files whose path starts
# with `_`, so we can't host the function directly at /__/* — this
# same-origin rewrite is the workaround. The browser keeps seeing /__/*;
# the function maps the path back to /__/* internally when proxying
# upstream to chord-1a556.firebaseapp.com.
# These rules MUST come before the SPA catch-all below, otherwise /__/*
# would fall through to index.html.
/__/auth/*       /auth-proxy/auth/:splat       200
/__/firebase/*   /auth-proxy/firebase/:splat   200

# SPA fallback — every other path serves the React app.
/*               /index.html                   200
